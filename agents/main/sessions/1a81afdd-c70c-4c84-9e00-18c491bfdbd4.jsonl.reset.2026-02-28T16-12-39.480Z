{"type":"message","id":"e9a49c84","parentId":"d9148c61","timestamp":"2026-02-28T15:40:33.861Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"chatcmpl-tool-944e6c68522a6a0f","name":"write","arguments":{"content":"#!/bin/bash\n\n# Telegram Notification Script\n# Sends notifications to Telegram bot\n\n# Configuration\nTELEGRAM_BOT_TOKEN=\"YOUR_BOT_TOKEN_HERE\"\nTELEGRAM_CHAT_ID=\"YOUR_CHAT_ID_HERE\"\n\n# Function to send message to Telegram\nsend_telegram_message() {\n    local message=\"$1\"\n    local parse_mode=\"${2:-Markdown}\"\n    \n    if [ -z \"$TELEGRAM_BOT_TOKEN\" ] || [ -z \"$TELEGRAM_CHAT_ID\" ]; then\n        echo \"Error: Telegram configuration not set\"\n        return 1\n    fi\n    \n    # Send message using curl\n    curl -s -X POST \"https://api.telegram.org/bot$TELEGRAM_BOT_TOKEN/sendMessage\" \\\n        -d \"chat_id=$TELEGRAM_CHAT_ID\" \\\n        -d \"text=$message\" \\\n        -d \"parse_mode=$parse_mode\" >/dev/null\n    \n    if [ $? -eq 0 ]; then\n        echo \"Message sent to Telegram\"\n        return 0\n    else\n        echo \"Failed to send message to Telegram\"\n        return 1\n    fi\n}\n\n# Function to send news alert\nsend_news_alert() {\n    local news_title=\"$1\"\n    local news_content=\"$2\"\n    local source=\"$3\"\n    \n    local message=\"📢 *أخبار عاجلة عن الأسهم*\n\n\"\n    message+=\"*العنوان:* $news_title\\n\"\n    message+=\"*الخبر:* $news_content\\n\"\n    message+=\"*المصدر:* $source\\n\"\n    message+=\"\\n📊 تأثير طويل الأجل: مهم على المدى الطويل\"\n    \n    send_telegram_message \"$message\"\n}\n\n# Function to send weekly report summary\nsend_weekly_report() {\n    local report_file=\"$1\"\n    local summary=\"$2\"\n    \n    local message=\"📈 *تقرير السوق الأسبوعي*\n\n\"\n    message+=\"*ملخص السوق:* $summary\\n\"\n    message+=\"\\n📄 *التفاصيل الكاملة:*\n\"\n    message+=\"- أداء السوق\\n\"\n    message+=\"- أهم الأخبار\\n\"\n    message+=\"- تحليل الأسهم\\n\"\n    message+=\"- فرص جديدة\\n\"\n    message+=\"\\n💰 *تذكير الاستثمار:* EGP 2,000 شهرياً\"\n    \n    send_telegram_message \"$message\"\n    \n    # Also send the report file if needed\n    # (This would require additional setup for file uploads)\n}\n\n# Example usage\nmain() {\n    local message_type=\"$1\"\n    shift\n    \n    case \"$message_type\" in\n        \"news\")\n            send_news_alert \"$1\" \"$2\" \"$3\"\n            ;;\n        \"weekly\")\n            send_weekly_report \"$1\" \"$2\"\n            ;;\n        \"test\")\n            send_telegram_message \"اختبار تجريبي ناجح! نظام تحليل الأسهم يعمل بشكل صحيح\"\n            ;;\n        *)\n            echo \"Usage: $0 {news|weekly|test} [parameters]\"\n            exit 1\n            ;;\n    esac\n}\n\n# Execute main function\nmain \"$@\"","path":"/home/kero/.openclaw/workspace/telegram-notifier.sh"}}],"api":"openai-completions","provider":"openrouter","model":"arcee-ai/trinity-large-preview:free","usage":{"input":22844,"output":1394,"cacheRead":0,"cacheWrite":0,"totalTokens":24238,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772293163510}}
